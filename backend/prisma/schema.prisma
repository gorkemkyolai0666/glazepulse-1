generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  manager
  binder
}

enum PressType {
  letterpress
  perfect_bind
  saddle_stitch
  case_bind
  hand_bind
  restoration
}

enum PressStatus {
  available
  in_use
  cooling
  maintenance
  offline
}

enum JobStatus {
  scheduled
  in_progress
  completed
  failed
}

enum BindingType {
  case_binding
  perfect_binding
  saddle_stitch
  restoration
  gold_tooling
  custom
}

enum MaintenancePriority {
  low
  medium
  high
  urgent
}

enum MaintenanceStatus {
  open
  in_progress
  completed
  cancelled
}

enum FinishingCategory {
  edge_gilding
  marbling
  tooling
  cover_design
  quality_check
  other
}

enum FinishingStatus {
  scheduled
  in_progress
  completed
  overdue
}

enum ServiceCategory {
  case_binding
  restoration
  gold_tooling
  studio_rental
  rush_service
  other
}

enum ServiceRateStatus {
  active
  upcoming
  archived
}

enum MaterialOrderStatus {
  pending
  in_progress
  completed
  delivered
}

model Bindery {
  id           String   @id @default(uuid())
  name         String
  phone        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?  @map("zip_code")
  totalPresses Int      @default(6) @map("total_presses")
  timezone     String   @default("America/Chicago")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users                User[]
  presses              Press[]
  bindingJobs          BindingJob[]
  pressMaintenance     PressMaintenance[]
  finishingChecklists  FinishingChecklist[]
  serviceRates         ServiceRate[]
  materialOrders       MaterialOrder[]

  @@map("binderies")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(owner)
  binderyId    String   @map("bindery_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bindery Bindery @relation(fields: [binderyId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Press {
  id           String      @id @default(uuid())
  binderyId    String      @map("bindery_id")
  name         String
  zone         String
  pressType    PressType   @default(letterpress) @map("press_type")
  pressModel   String?     @map("press_model")
  status       PressStatus @default(available)
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  bindery          Bindery            @relation(fields: [binderyId], references: [id], onDelete: Cascade)
  bindingJobs      BindingJob[]
  pressMaintenance PressMaintenance[]

  @@unique([binderyId, name])
  @@index([binderyId, status])
  @@map("presses")
}

model BindingJob {
  id           String      @id @default(uuid())
  binderyId    String      @map("bindery_id")
  pressId      String      @map("press_id")
  scheduledAt  DateTime    @map("scheduled_at")
  bindingType  BindingType @default(case_binding) @map("binding_type")
  cashAmount   Float       @default(0) @map("cash_amount")
  cardAmount   Float       @default(0) @map("card_amount")
  pageCount    Int         @default(1) @map("page_count")
  rushFee      Float       @default(0) @map("rush_fee")
  status       JobStatus   @default(scheduled)
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  bindery Bindery @relation(fields: [binderyId], references: [id], onDelete: Cascade)
  press   Press   @relation(fields: [pressId], references: [id], onDelete: Cascade)

  @@index([binderyId, scheduledAt])
  @@index([binderyId, status])
  @@map("binding_jobs")
}

model PressMaintenance {
  id          String              @id @default(uuid())
  binderyId   String              @map("bindery_id")
  pressId     String              @map("press_id")
  title       String
  description String?
  reportedAt  DateTime            @map("reported_at")
  completedAt DateTime?           @map("completed_at")
  priority    MaintenancePriority @default(medium)
  status      MaintenanceStatus   @default(open)
  cost        Float?
  notes       String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  bindery Bindery @relation(fields: [binderyId], references: [id], onDelete: Cascade)
  press   Press   @relation(fields: [pressId], references: [id], onDelete: Cascade)

  @@index([binderyId, status])
  @@index([binderyId, priority])
  @@map("press_maintenance")
}

model FinishingChecklist {
  id          String            @id @default(uuid())
  binderyId   String            @map("bindery_id")
  title       String
  description String?
  category    FinishingCategory @default(other)
  zone        String?
  scheduledAt DateTime          @map("scheduled_at")
  status      FinishingStatus   @default(scheduled)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  bindery Bindery @relation(fields: [binderyId], references: [id], onDelete: Cascade)

  @@index([binderyId, scheduledAt])
  @@map("finishing_checklists")
}

model ServiceRate {
  id              String            @id @default(uuid())
  binderyId       String            @map("bindery_id")
  title           String
  rateCategory    ServiceCategory   @default(case_binding) @map("rate_category")
  status          ServiceRateStatus @default(active)
  basePrice       Float             @map("base_price")
  priceMultiplier Float             @default(1.0) @map("price_multiplier")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  bindery Bindery @relation(fields: [binderyId], references: [id], onDelete: Cascade)

  @@index([binderyId, rateCategory])
  @@map("service_rates")
}

model MaterialOrder {
  id           String              @id @default(uuid())
  binderyId    String              @map("bindery_id")
  customerName String              @map("customer_name")
  materialType String              @map("material_type")
  supplierName String?             @map("supplier_name")
  status       MaterialOrderStatus @default(pending)
  price        Float               @default(0)
  notes        String?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  bindery Bindery @relation(fields: [binderyId], references: [id], onDelete: Cascade)

  @@index([binderyId, status])
  @@map("material_orders")
}
